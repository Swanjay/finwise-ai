# ═══════════════════════════════════════════
# FinWise — Environment Variables
# Copy to .env.local for local development
# ═══════════════════════════════════════════

# ── NextAuth ──────────────────────────────
NEXTAUTH_URL=https://finwise.my.id
NEXTAUTH_SECRET=          # openssl rand -base64 32
AUTH_SECRET=              # same as NEXTAUTH_SECRET

# ── Supabase (required) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App URL ──────────────────────────────
NEXT_PUBLIC_APP_URL=https://finwise.my.id

# ── Telegram Login ───────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC...
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot
TELEGRAM_CHANNEL_ID=-1001234567890
TELEGRAM_CHANNEL_URL=https://t.me/your_channel

# ── Admin Panel ──────────────────────────
ADMIN_EMAIL=admin@finwise.my.id
ADMIN_USER=admin
ADMIN_PASS=change-me

# ── Vercel KV (rate limiting, required in prod) ─
KV_REST_API_URL=https://xxx.upstash.io
KV_REST_API_TOKEN=...

# ── AI / OCR (optional) ─────────────────
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
GOOGLE_GENERATIVE_AI_API_KEY=...
OCR_SPACE_API_KEY=...

# ── Sentry (optional) ───────────────────
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=sntrys_...
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# ── Langfuse (optional) ─────────────────
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
