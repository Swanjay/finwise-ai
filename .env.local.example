# ═══════════════════════════════════════════
# FinWise Environment Variables
# Copy to .env.local for local development
# ═══════════════════════════════════════════

# ── NextAuth ──────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret

# ── Supabase ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ───────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_CONTACT=@your_telegram

# ── Sentry (Error Tracking) ───────────────
# Create project at https://sentry.io → Settings → Projects → Copy DSN
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=finwise

# Auth token for source map uploads (Vercel build only)
# Create at https://sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=sntrys_xxx

# ── Langfuse (AI Observability) ───────────
# Create project at https://cloud.langfuse.com → Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx
# LANGFUSE_BASE_URL=https://cloud.langfuse.com  # default

# ── AI Providers (optional) ──────────────
GROQ_API_KEY=gsk_xxx
OPENAI_API_KEY=sk-xxx
GOOGLE_GENERATIVE_AI_API_KEY=xxx
